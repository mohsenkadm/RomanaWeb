
@{
    ViewData["Title"] = "الاشعارات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid">
            <div class="row">
                <div class="form-group col-md-6  alignright">
                    <label class="text-primary">عنوان الاشعار</label>
                    <input type="text" id="Title" autocomplete="off" name="Title" class="form-control alignright" placeholder="اكتب عنوان الاشعار" />
                </div>
                <div class="form-group col-md-6  alignright">
                    <label class="text-primary">تفاصيل الاشعار</label>
                    <input type="text" id="Details" autocomplete="off" name="Details" class="form-control alignright" placeholder="اكتب تفاصيل الاشعار" />
                </div>
                <div class="row col-md-12 alignright">
                    <label class="text-primary">اختيار صورة</label>
                    <input type="file" placeholder="اختيار الصورة" class=" alignright" autocomplete="off" name="imageca" id="imageca" />
                </div>
            </div> 
            <button type="button" class="btn btn-secondary" data-dismiss="modal">اغلاق</button>
            <button type="button" class="btn btn-success" id="save">حفظ</button>
        </div>
    </div>
</div>
<div id="mydiv">
    <script>
         
        $("#save").on("click", (e) => {
            e.preventDefault();

            if ($("#Title").val() === "" || $("#Title").val().trim() === "") {
                md.showNotification("رجاءا ادخل العنوان ");
                return;
            }
            if ($("#Details").val() === "" || $("#Details").val().trim() === "") {
                md.showNotification("رجاءا ادخل التفاصيل ");
                return;
            }
            var fileUpload = $("#imageca").get(0);
            var files = fileUpload.files;
            var data = new FormData(); 
            data.append('Title', $("#Title").val());
            data.append('Details', $("#Details").val());
            if (files.length === 0) {
                data.append('FileChoose', files[0]);
            }
            else {
                data.append('FileChoose', files[0]);
            } 

            call_ajax_withfile("POST", "Notification/PostWithImage", data, null);
        });

    </script>
</div>
