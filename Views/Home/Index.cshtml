@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* === Beautified summary cards (Section: dashboard KPI redesign) === */
    .rm-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
        margin-bottom: 22px;
    }
    .rm-kpi {
        position: relative;
        border-radius: 18px;
        padding: 22px 20px 18px;
        color: #fff;
        overflow: hidden;
        box-shadow: 0 10px 24px rgba(15,23,42,.10);
        animation: rmKpiIn .55s ease-out both;
        transition: transform .25s ease, box-shadow .25s ease;
    }
    .rm-kpi:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 30px rgba(15,23,42,.18);
    }
    .rm-kpi::after {
        content: "";
        position: absolute; inset: 0;
        background: radial-gradient(circle at top left, rgba(255,255,255,.18), transparent 60%);
        pointer-events: none;
    }
    .rm-kpi .rm-kpi-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        background: rgba(255,255,255,.22);
        display: inline-flex;
        align-items: center; justify-content: center;
        margin-bottom: 14px;
        backdrop-filter: blur(4px);
    }
    .rm-kpi .rm-kpi-icon i { font-size: 28px; color: #fff; }
    .rm-kpi .rm-kpi-label {
        font-size: .88rem;
        font-weight: 500;
        opacity: .92;
        margin: 0 0 6px 0;
    }
    .rm-kpi .rm-kpi-value {
        font-size: 1.95rem;
        font-weight: 800;
        line-height: 1.1;
        margin: 0;
        letter-spacing: -.5px;
    }
    .rm-kpi .rm-kpi-sub {
        margin-top: 10px;
        font-size: .75rem;
        opacity: .85;
        display: flex; align-items: center; gap: 4px;
    }
    /* Color variants */
    .rm-kpi-violet  { background: linear-gradient(135deg,#6366f1,#8b5cf6); }
    .rm-kpi-emerald { background: linear-gradient(135deg,#10b981,#059669); }
    .rm-kpi-cyan    { background: linear-gradient(135deg,#06b6d4,#0891b2); }
    .rm-kpi-amber   { background: linear-gradient(135deg,#f59e0b,#d97706); }
    .rm-kpi-rose    { background: linear-gradient(135deg,#f43f5e,#e11d48); }
    .rm-kpi-sky     { background: linear-gradient(135deg,#0ea5e9,#0284c7); }
    .rm-kpi-purple  { background: linear-gradient(135deg,#a855f7,#7e22ce); }

    @@keyframes rmKpiIn {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .rm-kpi:nth-child(1){ animation-delay:.05s }
    .rm-kpi:nth-child(2){ animation-delay:.10s }
    .rm-kpi:nth-child(3){ animation-delay:.15s }
    .rm-kpi:nth-child(4){ animation-delay:.20s }
    .rm-kpi:nth-child(5){ animation-delay:.25s }
    .rm-kpi:nth-child(6){ animation-delay:.30s }
    .rm-kpi:nth-child(7){ animation-delay:.35s }

    .dash-chart-card {
        animation: rmKpiIn 0.6s ease-out both;
        border-radius: 14px;
        overflow: hidden;
    }
    .dash-chart-container {
        position: relative;
        height: 280px;
    }
</style>

<div class="content" style="direction:rtl;">
    <div class="container-fluid">
        <!-- Welcome Banner -->
        <div class="row mb-4">
            <div class="col-12">
                <div style="background:linear-gradient(135deg,#4f46e5,#6366f1);border-radius:16px;padding:28px 32px;color:#fff;animation:rmKpiIn 0.4s ease-out;">
                    <h4 style="font-weight:800;margin:0 0 6px 0;font-size:1.3rem;"><i class="material-icons" style="vertical-align:middle;margin-left:8px;">dashboard</i>مرحباً بك في لوحة التحكم</h4>
                    <p style="margin:0;opacity:0.85;font-size:0.92rem;">إليك ملخص سريع لأهم الإحصائيات والبيانات في النظام</p>
                </div>
            </div>
        </div>

        <!-- Summary KPI cards -->
        <div class="rm-summary-grid">
            <div class="rm-kpi rm-kpi-amber">
                <div class="rm-kpi-icon"><i class="material-icons">person</i></div>
                <p class="rm-kpi-label">عدد الزبائن</p>
                <h3 class="rm-kpi-value" id="CountUser">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">people</i> اجمالي المسجلين</div>
            </div>
            <div class="rm-kpi rm-kpi-emerald">
                <div class="rm-kpi-icon"><i class="material-icons">store</i></div>
                <p class="rm-kpi-label">عدد المطاعم</p>
                <h3 class="rm-kpi-value" id="CountRes">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">storefront</i> المتاجر النشطة</div>
            </div>
            <div class="rm-kpi rm-kpi-cyan">
                <div class="rm-kpi-icon"><i class="material-icons">category</i></div>
                <p class="rm-kpi-label">عدد الاقسام</p>
                <h3 class="rm-kpi-value" id="CountCateg">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">label</i> التصنيفات</div>
            </div>
            <div class="rm-kpi rm-kpi-violet">
                <div class="rm-kpi-icon"><i class="material-icons">list</i></div>
                <p class="rm-kpi-label">عدد الاصناف</p>
                <h3 class="rm-kpi-value" id="CountSubCateg">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">format_list_bulleted</i> الاصناف الفرعية</div>
            </div>
            <div class="rm-kpi rm-kpi-rose">
                <div class="rm-kpi-icon"><i class="material-icons">inventory_2</i></div>
                <p class="rm-kpi-label">عدد المنتجات</p>
                <h3 class="rm-kpi-value" id="CountProd">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">shopping_bag</i> اجمالي الاصناف</div>
            </div>
            <div class="rm-kpi rm-kpi-sky">
                <div class="rm-kpi-icon"><i class="material-icons">shopping_cart</i></div>
                <p class="rm-kpi-label">عدد الطلبات</p>
                <h3 class="rm-kpi-value" id="CountOrder">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">receipt_long</i> اجمالي الطلبات</div>
            </div>
            <div class="rm-kpi rm-kpi-purple">
                <div class="rm-kpi-icon"><i class="material-icons">attach_money</i></div>
                <p class="rm-kpi-label">مبلغ الطلبات</p>
                <h3 class="rm-kpi-value" id="PriceSale">0</h3>
                <div class="rm-kpi-sub"><i class="material-icons" style="font-size:14px">payments</i> الايرادات</div>
            </div>
        </div>

        <!-- Dashboard Charts -->
        <div class="row mt-3">
            <div class="col-lg-8">
                <div class="card dash-chart-card" style="animation-delay:0.4s">
                    <div class="card-header" style="background:#fff !important;border-bottom:1px solid #e2e8f0;text-align:right;">
                        <h4 class="card-title" style="color:#1e293b;"><i class="material-icons" style="vertical-align:middle;color:#4f46e5;margin-left:6px;">trending_up</i> ملخص الطلبات الاخيرة</h4>
                    </div>
                    <div class="card-body">
                        <div class="dash-chart-container">
                            <canvas id="dashRecentOrders"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card dash-chart-card" style="animation-delay:0.5s">
                    <div class="card-header" style="background:#fff !important;border-bottom:1px solid #e2e8f0;text-align:right;">
                        <h4 class="card-title" style="color:#1e293b;"><i class="material-icons" style="vertical-align:middle;color:#0891b2;margin-left:6px;">pie_chart</i> توزيع الاقسام</h4>
                    </div>
                    <div class="card-body">
                        <div class="dash-chart-container">
                            <canvas id="dashCategoriesPie"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid" style="direction:rtl;">
    <div class="text-center py-3" id="date" style="color:#94a3b8;font-size:0.82rem;">
        © 2024 رمانة — صُنع بـ <i class="material-icons" style="font-size:14px;vertical-align:middle;color:#dc2626;">favorite</i> بواسطة
        <a href="#" style="color:#4f46e5;text-decoration:none;">Developer Mohsen</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<div id="mydiv">
    <script>
        var dashCharts = {};

        $(document).ready(function () {
            call_ajax("GET", "Home/GetCountForMain", null, filldatacount);
            loadDashCharts();
        });

        function filldatacount(data) {
            animateCount('#CountUser', data.countUser);
            animateCount('#CountRes', data.countRes);
            animateCount('#CountCateg', data.countCateg);
            animateCount('#CountSubCateg', data.countSubCateg);
            animateCount('#CountProd', data.countProd);
            animateCount('#CountOrder', data.countOrder);
            $('#PriceSale').html(data.priceSale);
        }

        function animateCount(selector, target) {
            var num = parseInt(target) || 0;
            var el = $(selector);
            var current = 0;
            var step = Math.max(1, Math.floor(num / 40));
            var timer = setInterval(function () {
                current += step;
                if (current >= num) {
                    current = num;
                    clearInterval(timer);
                }
                el.text(current.toLocaleString());
            }, 30);
        }

        function loadDashCharts() {
            var today = new Date();
            var monthAgo = new Date();
            monthAgo.setMonth(monthAgo.getMonth() - 1);
            var df = monthAgo.toISOString().split('T')[0];
            var dt = today.toISOString().split('T')[0];

            call_ajax("GET", "Orders/GetAll", {
                OrderNo: '', RestaurantName: '', datefrom: df, dateto: dt, CountriesId: 0, state: 0
            }, function (data) {
                if (!data) return;
                var dailyMap = {};
                data.forEach(function (o) {
                    var d = new Date(o.orderDate).toLocaleDateString('en-GB');
                    dailyMap[d] = (dailyMap[d] || 0) + 1;
                });
                var keys = Object.keys(dailyMap).slice(-14);
                renderDashChart('dashRecentOrders', 'bar', {
                    labels: keys,
                    datasets: [{
                        label: 'عدد الطلبات',
                        data: keys.map(k => dailyMap[k]),
                         backgroundColor: 'rgba(79,70,229,0.15)',
                        borderColor: '#4f46e5',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                });
            });

            call_ajax("GET", "Restaurant/GetAll", { Name: '' }, function (data) {
                if (!data) return;
                var catMap = {};
                data.forEach(function (r) {
                    var cat = r.categoriesName || 'غير محدد';
                    catMap[cat] = (catMap[cat] || 0) + 1;
                });
                var cats = Object.entries(catMap).sort((a, b) => b[1] - a[1]).slice(0, 6);
                var palette = [
                    'rgba(79,70,229,0.75)', 'rgba(8,145,178,0.75)', 'rgba(5,150,105,0.75)',
                    'rgba(217,119,6,0.75)', 'rgba(220,38,38,0.75)', 'rgba(13,148,136,0.75)'
                ];
                renderDashChart('dashCategoriesPie', 'doughnut', {
                    labels: cats.map(c => c[0]),
                    datasets: [{
                        data: cats.map(c => c[1]),
                        backgroundColor: palette.slice(0, cats.length),
                        borderWidth: 2
                    }]
                });
            });
        }

        function renderDashChart(id, type, data) {
            if (dashCharts[id]) dashCharts[id].destroy();
            var ctx = document.getElementById(id);
            if (!ctx) return;
            var opts = {
                responsive: true, maintainAspectRatio: false,
                animation: { duration: 1200, easing: 'easeOutQuart' },
                plugins: { legend: { labels: { color: '#475569', font: { family: 'Tajawal', size: 13 } } } }
            };
            if (type === 'bar' || type === 'line') {
                opts.scales = {
                    x: { ticks: { color: '#64748b', font: { family: 'Tajawal' } }, grid: { color: '#e2e8f0' } },
                    y: { ticks: { color: '#64748b', font: { family: 'Tajawal' } }, grid: { color: '#f1f5f9' } }
                };
            }
            dashCharts[id] = new Chart(ctx, { type: type, data: data, options: opts });
        }
    </script>
</div>

