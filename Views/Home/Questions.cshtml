@{
    ViewData["Title"] = "الأسئلة الشائعة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid">

            <!-- Page Summary -->
            <div class="rm-page-summary">
                <div class="rm-summary-icon bg-teal"><i class="material-icons">help_outline</i></div>
                <div class="rm-summary-body">
                    <h4>ادارة الأسئلة الشائعة</h4>
                    <p>عرض وادارة الأسئلة الشائعة والإجابات المعروضة للزبائن. يمكنك ترتيب الأسئلة حسب الأهمية والتحكم في اظهارها او اخفائها.</p>
                </div>
            </div>

            <div class="rm-filter-bar">
                <div class="row">
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2">
                        <div class="text-center wow fadeInDown">
                            <label class="mb-2"> </label>
                            <button type="button" class="btn btn-success btnwidth" style="text-align:center; width:100%;" data-toggle="modal" data-target="#QuestionModal">اضافة جديد <i class='material-icons'>add</i> </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header card-header-primary" style="text-align:right">
                            <h4 class="card-title ">الأسئلة الشائعة</h4>
                            <p class="card-category">جدول لعرض الأسئلة والإجابات داخل التطبيق</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="text-align: right;">
                                <table class="table table-hover">
                                    <thead class=" ">
                                        <tr>
                                            <th scope="col">عرض</th>
                                            <th scope="col">السؤال</th>
                                            <th scope="col">الإجابة</th>
                                            <th scope="col">ترتيب العرض</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableQuestions">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="QuestionModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dark-edition">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">اضافة سؤال جديد</h5>
                <button type="button" id="closeQuestion" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="form-group col-md-12 alignright">
                        <label class="text-primary">السؤال</label>
                        <input type="text" id="QuestionText" autocomplete="off" name="QuestionText" class="form-control alignright" placeholder="اكتب السؤال" />
                    </div>
                    <div class="form-group col-md-12 alignright">
                        <label class="text-primary">الإجابة</label>
                        <textarea id="AnswerText" autocomplete="off" name="AnswerText" class="form-control alignright" placeholder="اكتب الإجابة" rows="4"></textarea>
                    </div>
                    <div class="form-group col-md-12 alignright">
                        <label class="text-primary">ترتيب العرض</label>
                        <input type="number" id="DisplayOrder" autocomplete="off" name="DisplayOrder" class="form-control alignright" placeholder="ترتيب العرض" value="0" />
                    </div>
                    <div class="form-group col-md-12 alignright">
                        <label class="text-primary">عرض</label>
                        <div class='form-check col-md-6 alignright'>
                            <label class='form-check-label'>
                                <input class='form-check-input' type='checkbox' id='IsShowQuestion'>
                                <span class='form-check-sign'>
                                    <span class='check'></span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="closeQuestionBtn" data-dismiss="modal">اغلاق</button>
                <button type="button" class="btn btn-success" id="saveQuestion">حفظ</button>
            </div>
        </div>
    </div>
</div>

<div id="mydiv">
    <script>
       
        $(document).ready(function () {
            RefreshQuestions();
        });

        $("#closeQuestion").on("click", (e) => {
            e.preventDefault();
            aftersaveQuestion();
        });

        $("#closeQuestionBtn").on("click", (e) => {
            e.preventDefault();
            aftersaveQuestion();
        });

        $("#saveQuestion").on("click", (e) => {
            e.preventDefault();

            if ($("#QuestionText").val().trim() === '') {
                md.showNotification("رجاءا ادخل السؤال");
                return;
            }

            if ($("#AnswerText").val().trim() === '') {
                md.showNotification("رجاءا ادخل الإجابة");
                return;
            }

            var IsShow = false;
            if ($('#IsShowQuestion').is(":checked")) {
                IsShow = true;
            }

            var data = {
                QuestionId: _QuestionId,
                QuestionText: $("#QuestionText").val(),
                AnswerText: $("#AnswerText").val(),
                DisplayOrder: $("#DisplayOrder").val(),
                IsShow: IsShow
            };

            call_ajax("POST", "Questions/Post", data, aftersaveQuestion);
        });
    </script>
</div>