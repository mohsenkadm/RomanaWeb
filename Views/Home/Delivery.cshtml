
@{
    ViewData["Title"] = "المدن";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid">

            <div class="container alignright" style="margin:2% 0;">
                <div class="row">
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <label class="mb-2">رقم الطلب</label>
                        <input type="text" id="OrderNo" name="OrderNo" class="form-control alignright" placeholder="ابحث عن رقم الطلب" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <label class="mb-2">اسم الشخص</label>
                        <input type="text" id="Name" name="Name" class="form-control alignright" placeholder="ابحث عن اسم الشخص" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <label class="mb-2">اسم المطعم</label>
                        <input type="text" id="RestaurantName" name="RestaurantName" class="form-control alignright" placeholder="ابحث عن اسم المطعم" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <label class="mb-2">تاريخ الى</label>
                        <input type="date" name="dateto" id="dateto" class="form-control alignright" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <label class="mb-2">تاريخ من</label>
                        <input type="date" name="datefrom" id="datefrom" class="form-control alignright" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 ">
                        <p>اختيار المحافظة</p>
                        <select class="form-control text-right" style="background-color: #1a2035;" name="CountriesId" id="CountriesId">
                        </select>
                    </div>
                    <div class="col-lg-4 col-md-2 col-sm-2 col-xs-2">
                        <div class="text-center wow fadeInDown" style="text-align:left;">
                            <label class="mb-2"></label>
                            <button type="button" id="search-btn" class="btn btn-info btnwidth" style="text-align:center; width:100%;">بحث</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header card-header-primary" style="text-align:right">
                            <h4 class="card-title ">الطلبات التوصيل</h4>
                            <p class="card-category">جدول لعرض طلبات التوصيل داخل التطبيق</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="text-align: right;">
                                <table class="table table-hover">
                                    <thead class=" ">
                                        <tr>   
                                            <th scope="col">اسم المحافظة</th> 
                                            <th scope="col">اسم المدينة</th> 
                                            <th scope="col">اقرب نقطة دالة</th>
                                            <th scope="col">المبلغ الكلي</th>
                                            <th scope="col">مبلع التوصيل</th>
                                            <th scope="col">تاريخ الطلب</th>
                                            <th scope="col">ملاحظات</th>
                                            <th scope="col">رقم الهاتف</th>
                                            <th scope="col">العنوان</th>
                                            <th scope="col">اسم الشخص</th>
                                            <th scope="col">اسم المطعم</th>
                                            <th scope="col">رقم الطلب</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableDelivery">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
 
<div id="mydiv">
    <script>
        function selectCountriesId(data) {
            var s = '<option value="0">اختيار المحافظة</option>';
            $('#CountriesId').append(s);
            $.each(data, function (i, item) {
                var ss = '<option value="' + item.countriesId + '">' + item.countriesName + '</option>';
                $('#CountriesId').append(ss);
            });
        };
        
        $("#search-btn").on("click", (e) => {
            e.preventDefault();
            RefreshDelivery();
        });

        $(document).ready(function () { 
            call_ajax("GET", "Countries/GetAll", null, selectCountriesId);
            var now = new Date();
            var day = ("0" + now.getDate()).slice(-2);
            var month = ("0" + (now.getMonth() + 1)).slice(-2);
            var today = now.getFullYear() + "-" + (month) + "-" + (day);
            $("#datefrom").val(today);
            $("#dateto").val(today);
            RefreshDelivery();
        });
      

    </script>
</div>




