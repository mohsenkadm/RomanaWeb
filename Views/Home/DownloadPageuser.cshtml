
@{
    ViewData["Title"] = "تحميل تطبيق رمانة";
    Layout = "~/Views/Shared/_Layoutfordownload.cshtml";
}

<div class="dl-section-title">حمّل التطبيق الآن</div>
<div class="dl-store-row">
    <a class="dl-store-btn" onclick="urlapp()" href="javascript:void(0)">
        <i class="fab fa-google-play"></i>
        <span class="dl-btn-text">
            <span class="dl-btn-sub">تحميل من</span>
            <span class="dl-btn-main">Google Play</span>
        </span>
    </a>
    <a class="dl-store-btn" onclick="urlapple()" href="javascript:void(0)">
        <i class="fab fa-apple"></i>
        <span class="dl-btn-text">
            <span class="dl-btn-sub">تحميل من</span>
            <span class="dl-btn-main">App Store</span>
        </span>
    </a>
</div>

<div class="dl-divider"></div>

<div class="dl-section-title">تواصل معنا على وسائل التواصل الاجتماعي</div>
<div class="dl-social-row">
    <a class="dl-social-btn" onclick="urltelegram()" href="javascript:void(0)">
        <i class="fab fa-telegram"></i>
        <span>تيليغرام</span>
    </a>
    <a class="dl-social-btn" onclick="urlinsta()" href="javascript:void(0)">
        <i class="fab fa-instagram"></i>
        <span>انستغرام</span>
    </a>
    <a class="dl-social-btn" onclick="urlface()" href="javascript:void(0)">
        <i class="fab fa-facebook"></i>
        <span>فيسبوك</span>
    </a>
</div>

@section Scripts {
<script>
    function urlapple()   { window.open('https://apps.apple.com/us/app/rummana-%D8%B1%D9%85%D8%A7%D9%86%D8%A9/id6471382620'); }
    function urlwhatsapp(){ window.open('https://wa.me/+9647850047002'); }
    function urlface()    { window.open('https://www.facebook.com/profile.php?id=61551440293842&mibextid=LQQJ4d'); }
    function urlinsta()   { window.open('https://www.instagram.com/rummana.food?igsh=dHJxMjhscmdkZGJm'); }
    function urltelegram(){ window.open('https://t.me/rummana_app'); }
    function urlapp()     { window.open('https://play.google.com/store/apps/details?id=com.romanashop'); }
</script>
}
