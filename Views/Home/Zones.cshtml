@{
    ViewData["Title"] = "إدارة المناطق";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="container-fluid" style="direction:rtl;">

        <div class="rm-page-summary">
            <div class="rm-summary-icon bg-info"><i class="material-icons">map</i></div>
            <div class="rm-summary-body">
                <h4>إدارة المناطق ومصفوفة الأسعار (Zones)</h4>
                <p>
                    رفع المناطق (Polygons) ومصفوفة الأسعار من ملف Excel.
                    تستخدمها خوارزمية التسعير لاحتساب أجور التوصيل بين المناطق.
                </p>
            </div>
            <div class="rm-summary-stats">
                <div class="rm-stat"><span class="rm-stat-value" id="zonesCount">-</span><span class="rm-stat-label">عدد المناطق</span></div>
                <div class="rm-stat"><span class="rm-stat-value" id="matrixCount">-</span><span class="rm-stat-label">عدد الأسعار</span></div>
            </div>
        </div>

        <div class="row">

            <!-- Upload Zones -->
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header card-header-info" style="text-align:right">
                        <h4 class="card-title"><i class="material-icons">upload_file</i> رفع المناطق (Polygons)</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            صيغة الملف (الورقة الأولى):
                            <br /><strong>العمود A:</strong> اسم المنطقة
                            <br /><strong>العمود B:</strong> GeoJSON Polygon (سطر واحد)
                        </p>
                        <pre style="background:#f5f5f5;padding:8px;font-size:11px;direction:ltr;text-align:left">
{"type":"Polygon","coordinates":[[[44.36,33.31],[44.40,33.31],[44.40,33.34],[44.36,33.34],[44.36,33.31]]]}
                        </pre>
                        <div class="row col-md-12 alignright" style="margin-bottom:12px">
                            <label class="text-primary">اختر الملف</label>
                            <input type="file" class="form-control alignright" id="zonesFile" name="zonesFile" accept=".xlsx,.xls" autocomplete="off" />
                        </div>
                        <button id="uploadZonesBtn" type="button" class="btn btn-info">
                            رفع المناطق <i class="material-icons">cloud_upload</i>
                        </button>
                        <a href="/zones/template/zones" class="btn btn-secondary" download>
                            تنزيل ملف نموذجي <i class="material-icons">download</i>
                        </a>
                        <div id="zonesResult" class="mt-3"></div>
                    </div>
                </div>
            </div>

            <!-- Upload Price Matrix -->
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header card-header-success" style="text-align:right">
                        <h4 class="card-title"><i class="material-icons">grid_on</i> رفع مصفوفة الأسعار</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            ارفع المناطق أولاً، ثم ارفع المصفوفة:
                            <br /><strong>العمود A:</strong> اسم منطقة المصدر (From)
                            <br /><strong>العمود B:</strong> اسم منطقة الوجهة (To)
                            <br /><strong>العمود C:</strong> السعر (IQD)
                        </p>
                        <div class="row col-md-12 alignright" style="margin-bottom:12px">
                            <label class="text-primary">اختر الملف</label>
                            <input type="file" class="form-control alignright" id="matrixFile" name="matrixFile" accept=".xlsx,.xls" autocomplete="off" />
                        </div>
                        <button id="uploadMatrixBtn" type="button" class="btn btn-success">
                            رفع المصفوفة <i class="material-icons">cloud_upload</i>
                        </button>
                        <a href="/zones/template/matrix" class="btn btn-secondary" download>
                            تنزيل ملف نموذجي <i class="material-icons">download</i>
                        </a>
                        <div id="matrixResult" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Existing Zones table -->
        <div class="card">
            <div class="card-header card-header-primary" style="text-align:right">
                <h4 class="card-title"><i class="material-icons">list</i> المناطق المسجلة</h4>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-hover">
                    <thead class="text-primary">
                        <tr>
                            <th>#</th>
                            <th>الاسم</th>
                            <th>مفعّلة</th>
                            <th style="text-align:left">GeoJSON</th>
                        </tr>
                    </thead>
                    <tbody id="zonesTableBody"></tbody>
                </table>
            </div>
        </div>

        <!-- Existing Price Matrix table -->
        <div class="card">
            <div class="card-header card-header-rose" style="text-align:right">
                <h4 class="card-title"><i class="material-icons">price_change</i> مصفوفة الأسعار</h4>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-hover">
                    <thead class="text-rose">
                        <tr>
                            <th>#</th>
                            <th>من منطقة (Id)</th>
                            <th>الى منطقة (Id)</th>
                            <th>السعر</th>
                        </tr>
                    </thead>
                    <tbody id="matrixTableBody"></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script src="~/js/Zones.js" asp-append-version="true"></script>
